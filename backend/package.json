{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server.ts",
    "proxy": "wsl -d Ubuntu -e bash -c \"cd ~/fcc/nvidia-nim && ~/.local/bin/uv run uvicorn server:app --host 0.0.0.0 --port 8082\"",
    "dev": "concurrently \"npm run dev:server\" \"npm run proxy\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "frontend": "cd ../frontend && npm run dev",
    "app": "cd ../nexus-app && npm run start",
    "all": "concurrently \"npm run dev\" \"npm run frontend\" \"npm run app\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
